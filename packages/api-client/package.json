{
  "name": "@about-time/api-client",
  "version": "0.1.0",
  "description": "Typed HTTP client for about-time backend API",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./templates": {
      "types": "./dist/templates.d.ts",
      "import": "./dist/templates.js"
    },
    "./libraries": {
      "types": "./dist/libraries.d.ts",
      "import": "./dist/libraries.js"
    },
    "./templateVariables": {
      "types": "./dist/templateVariables.d.ts",
      "import": "./dist/templateVariables.js"
    },
    "./composites": {
      "types": "./dist/composites.d.ts",
      "import": "./dist/composites.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@about-time/types": "*",
    "@tannerbroberts/about-time-core": "*",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "typescript": "~5.9.3"
  }
}
