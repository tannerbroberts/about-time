{
  "name": "@about-time/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for about-time frontend and backend",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "import": "./dist/database.js"
    },
    "./library": {
      "types": "./dist/library.d.ts",
      "import": "./dist/library.js"
    },
    "./confidence": {
      "types": "./dist/confidence.d.ts",
      "import": "./dist/confidence.js"
    },
    "./confidenceMath": {
      "types": "./dist/confidenceMath.d.ts",
      "import": "./dist/confidenceMath.js"
    },
    "./composite": {
      "types": "./dist/composite.d.ts",
      "import": "./dist/composite.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@tannerbroberts/about-time-core": "*"
  }
}
