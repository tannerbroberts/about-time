{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["npm install --legacy-peer-deps"]
    },
    "build": {
      "commands": [
        "npm run build --workspace=@tannerbroberts/about-time-core",
        "npm run build --workspace=@about-time/api-client",
        "npm run build --workspace=@about-time/backend",
        "npm run build --workspace=@about-time/frontend"
      ]
    }
  }
}
