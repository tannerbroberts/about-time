{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build --workspace=@tannerbroberts/about-time-core && npm run build --workspace=@about-time/backend"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=@about-time/backend",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
