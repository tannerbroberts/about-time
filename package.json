{
  "name": "about-time-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-user nutrition tracking app with offline-first support",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "packageManager": "npm@10.2.4"
}
