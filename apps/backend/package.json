{
  "name": "@about-time/backend",
  "version": "0.1.0",
  "description": "Backend API server for about-time",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "migrate:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@about-time/types": "*",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@lucia-auth/adapter-postgresql": "^3.0.0",
    "@tannerbroberts/about-time-core": "*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "lucia": "^3.2.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.39.1",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
