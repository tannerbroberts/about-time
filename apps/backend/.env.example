# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/about_time

# Redis
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
PORT=3001

# Session
SESSION_SECRET=your-random-64-char-secret-here-change-in-production

# OAuth (optional - leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS
CORS_ORIGIN=http://localhost:5173
